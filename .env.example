# --- Telegram ---
# Get from @BotFather
TELEGRAM_BOT_TOKEN=

# Your personal chat_id (talk to @userinfobot to get it).
# Bot will only respond to this chat_id; everyone else is ignored.
TELEGRAM_OWNER_CHAT_ID=

# --- Cadence (seconds) ---
HRRR_POLL_SECONDS=3600
METAR_POLL_SECONDS=600
POLYMARKET_POLL_SECONDS=300
RECOMPUTE_SECONDS=600

# --- Alert thresholds ---
ALERT_BUCKET_PROB_DROP=0.15        # absolute drop in leader-bucket prob that triggers alert
ALERT_MIN_FAIR_FOR_WATCH=0.05      # don't spam if pinned bucket is already near-zero

# --- Polymarket ---
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# --- Logging ---
LOG_LEVEL=INFO
